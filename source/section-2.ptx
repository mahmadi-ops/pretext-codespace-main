<?xml version="1.0" encoding="utf-8"?>
<section xml:id="section-2" xmlns:xi="http://www.w3.org/2001/XInclude">
  <title>Including Interactive Graphics</title>
  <p>In this section, we will see an example 
    of a graph created using GeoGebra.</p>

  
<figure width="50%">
 <interactive geogebra="rqrxy7j9" shift-drag-zoom="yes"/>
<caption>Use the slider to observe that when <m>h\to 0</m>, the vector 
  <m>\frac{\vec{r}(t_0+h)-\vec{r}(t_0)}{h}</m> becomes parallel to the tangent line.</caption>
</figure>

<exercise label="mylabel">
  <webwork>
    <pg-code>
      Context("ImplicitPlane");
    </pg-code>
    <statement>
      <p>
        The answer is <m>x+y=1</m>.
      </p>
      <p>
        <var name="'x+y=1'" width="8"/>
      </p>
    </statement>
  </webwork>
</exercise>

<exercise label="mylabel2">
<webwork>
<pg-code>
loadMacros(
  "PGstandard.pl",
  "MathObjects.pl",
  "contextFraction.pl",
  "littleneck.pl",
  "PGgraphmacros.pl",
  "PGcourse.pl"
);

Context()->variables->are(n=>'Real',k=>'Real');
$a=random(2,2,1);$b=random(1,1,1); 
#$as=$a**2; $bs=$b**2;
if($a==3 & $b==1){$b=2}
$d=$a-$b;
#$apb=$a;

Context("Fraction");
Context()->variables->are(n=>'Real',k=>'Real',A=>'Real',B=>'Real');
$A=Compute("1/$a");
$B=Compute("-1/$a");
$g=Formula("1/[($a*k-$b)*($a*k+$d)]")->reduce;
$f=Formula("1/[$a^2*k^2+($a*$d-$a*$b)*k - $b*$d]")->reduce;
$F=Formula("A/($a*k-$b)+B/($a*k+$d)")->reduce;
$G=Formula("$A*(1/($a*k-$b)-1/($a*k+$d))")->reduce;
$S1=Formula("(1/($a*k-$b)-1/($a*k+$d))")->reduce;
$S2=Formula("1/$d-1/($a*n+$d)")->reduce;
$E1=Formula("$a*A+$a*B")->reduce;
$E2=Formula("$d*A-$b*B")->reduce;
$ans=Compute("$A/($a-$b)");
Context()->texStrings;
Context("Numeric");
Context()->variables->are(n=>'Real',k=>'Real');
Context()->texStrings;
BEGIN_TEXT
Determine whether the series converges, and if so find its sum.$PAR

\(\displaystyle \sum_{k=1}^{\infty} $f =\) \{ans_rule(50) \}
$PAR 
$BBOLD NOTE: $EBOLD Enter "DNE" if the sum does not exist.
$PAR
END_TEXT
ANS($ans->cmp);
</pg-code>
</webwork>
</exercise>

<exercise label="mylabel3">
<webwork>
  <pg-code>
    Context("LimitedNumeric");
    $a = Compute(random(1, 9));
    $b = Compute(random(1, 9));
    $c = $a + $b;
  </pg-code>

  <statement>
    <p>
      Compute <m><var name="$a"/> + <var name="$b"/></m>.
    </p>
    <instruction>
      Type your answer without using the <c>+</c> sign.
    </instruction>
    <p>
      The sum is <var name="$c" width="2"/>.
    </p>
  </statement>

  <solution>
    <p>
      <m><var name="$a"/> + <var name="$b"/> = <var name="$c"/></m>.
    </p>
  </solution>
</webwork>
</exercise>
</section>
